<div class="page-width section-{{ section.id }}-padding">
	<div class="flex">

		<div class="image-wrapper">
			{% if section.settings.side_image != blank %}
				{{ section.settings.side_image | image_url: width: 500 | image_tag: width: 500, class: 'image_by_side', alt: section.settings.side_image }}
			{% endif %}
		</div>

		<div class="text_wrapper">
			{% for block in section.blocks %}
				{% case block.type %}
					{% when 'heading' %}
						<h2 class="image_with_text__heading">{{ block.settings.heading }}</h2>
					{% when 'content' %}
						{% if block.settings.content != blank %}
							<div class="content_container">{{ block.settings.content }}</div>
						{% endif %}
				{% endcase %}
			{% endfor %}
		</div>
	</div>
</div>

<style>
	.flex {
		display: flex;
		flex-direction: {{ section.settings.mobile_layout }}
	}
	div#shopify-section-image-with-text {
    overflow: hidden;
	}
	.image_with_text__heading {
		margin-top: 1rem;
    margin-bottom: 1rem;
    font-size: 19px;
    font-family: 'PlantinMT','Times New Roman','serif';
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
    color: #626950;
    letter-spacing: .025em;
	}
	.content_container {
    margin-bottom: 1.5rem;
	}
	.text_wrapper p {
		font-family: 'GT America','Arial','sans-serif';
    font-size: 12px;
    font-weight: 400;
    letter-spacing: .5px;
    line-height: 1.6;
    display: block;
    font-style: normal;
	}
	.image_by_side {
    width: 100%;
		max-width: 500px;
    height: 100%;
    object-fit: cover;
	}
  
	.section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
	
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
		.flex {
			flex-direction: {{ section.settings.desktop_layout }};
			justify-content: space-between;
      gap: 2rem;
		}
    .text_wrapper {
      width: 50%;
    }
  }
</style>

{% schema %}
{
  "name": "Image with text",
  "class": "image-with-text",
  "settings": [
    {
      "type": "select",
      "id": "mobile_layout",
      "label": "Mobile Layout",
      "options": [
        {
          "value": "column-reverse",
          "label": "Text First"
        },
        {
          "value": "column",
          "label": "Image first"
        }
      ],
      "default": "column-reverse"
    },
    {
      "type": "select",
      "id": "desktop_layout",
      "label": "Desktop layout",
      "options": [
        {
          "label": "Text first",
          "value": "row-reverse"
        },
        {
          "value": "row",
          "label": "Image first"
        }
      ],
      "default": "row-reverse"
    },
    {
      "type": "image_picker",
      "id": "side_image",
      "label": "Side image"
    },
    {
      "type": "header",
      "content": "Padding section"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "name": "Heading",
      "type": "heading",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "range",
          "id": "font_size",
          "label": "Heading font size",
          "min": 12,
          "max": 100,
          "step": 1,
          "default": 30,
          "unit": "px"
        }
      ]
    },
    {
      "name": "Content",
      "type": "content",
      "settings": [
        {
          "type": "richtext",
          "id": "content",
          "label": "Content"
        }
      ]
    }
  ]
}
{% endschema %}