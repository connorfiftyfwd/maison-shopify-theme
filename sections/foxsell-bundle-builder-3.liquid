{{ 'foxsell-styles.css' | asset_url | stylesheet_tag }}
<script src="{{ 'foxsell-script.js' | asset_url }}" defer="defer"></script>

{% liquid
  assign app_namespace = 'app--67872686081'

  assign product = product | default: section.settings.product
  assign dynamic_add_ons_bundle_config = product.metafields[app_namespace].dynamic_add_ons_bundle.value

  assign bundle_id = dynamic_add_ons_bundle_config.bundle_id
  assign options = dynamic_add_ons_bundle_config.options_v2.value

  assign products = dynamic_add_ons_bundle_config.products.value

  assign categories = dynamic_add_ons_bundle_config.categories.value
  assign section_id = section.id

  assign default_variant_id = product.selected_or_first_available_variant.id
  assign default_bundle_option = options | where: 'variant_id', default_variant_id | first | default: options[0]

  assign currency_format = shop.money_format

  assign threshold = section.settings.dropdown_threshold

  if section.settings.cards_background != 'rgba(0,0,0,0)' and section.settings.cards_background != section.settings.section_background and section.settings.cards_background != blank
    assign as_card = true
  else
    assign as_card = false
  endif
%}

{% if options.size == 0 and request.design_mode or theme.role != 'main' %}
  <div class="isolate page-width">
    <div class="rich-text content-container color-{{ section.settings.color_scheme }} gradient{% if section.settings.full_width %} rich-text--full-width content-container--full-width{% endif %} section-{{ section_id }}-padding">
      <h2 class="rich-text__heading rte inline-richtext h1">Foxsell Bundle</h2>
      <h3 class="rich-text__heading rte inline-richtext h3">
        This section is only supported when "Quantity as an option" is selected when creating the bundle. Please try 
        with a different bundle.
      </h3>
    </div>
  </div>
{% else %}    

<style>
  :root {
    --fs-bg-color: {{ section.settings.section_background }};
    --fs-card-color: {{ section.settings.cards_background }};
    --fs-summary-background: {{ section.settings.summary_background }};
    --fs-summary-color: {{ section.settings.summary_color }};
    --fs-color: {{ section.settings.text_color }};
    --fs-highlight-color: {{ section.settings.highlight_color }};
    --fs-highlight-text-color: {{ section.settings.highlight_text_color }};
    --fs-highlight-2-color: {{ section.settings.highlight_color_2 }};
    --fs-highlight-text-2-color: {{ section.settings.highlight_text_color_2 }};
    --products-per-row: {{ section.settings.columns_desktop }};
    --products-per-row-mobile: {{- section.settings.columns_mobile -}};
    --fs-card-radius: 8px;
  }

  .fsb-wrapper {
    background: transparent;
  }

  /* Dropdown-specific styles */
  .fsb__dropdown-selector {
    {% comment %} margin-bottom: 2rem; {% endcomment %}
    width: 100%;
    margin-left: auto;
    margin-right: auto;
  }

  .fsb__bundle-add-to-cart {
    position: relative;
    top: -4rem; /* Adjust this value as needed */
    width: 60%;
  }

  .fsb__dropdown-group {
    display: flex;
    flex-direction: column;
    {% comment %} gap: 1rem; {% endcomment %}
    margin-bottom: 2rem;
  }

  .fsb__dropdown-item {
    position: relative;
  }



  {% comment %} .fsb__dropdown-select {
    {% comment %} width: 100%;
    padding: 1rem;
    border: 2px solid #e5e5e5;
    border-radius: var(--fs-card-radius);
    background: var(--fs-card-color);
    color: var(--fs-color);
    font-size: 1rem;
    cursor: pointer;
    appearance: none;
    background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' fill='none' viewBox='0 0 20 20'%3e%3cpath stroke='%236b7280' stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M6 8l4 4 4-4'/%3e%3c/svg%3e");
    background-position: right 1rem center;
    background-repeat: no-repeat;
    background-size: 1rem;
    padding-right: 3rem; {% endcomment %}
  } {% endcomment %}

  {% comment %} .fsb__dropdown-select:focus {
    outline: none;
    border-color: var(--fs-highlight-color);
    box-shadow: 0 0 0 3px rgba(0, 0, 0, 0.1);
  } {% endcomment %}

  .fsb__dropdown-option {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 0;
  }

  .fsb__dropdown-option-image {
    width: 40px;
    height: 40px;
    object-fit: cover;
    border-radius: 4px;
    flex-shrink: 0;
  }

  .fsb__dropdown-option-details {
    flex: 1;
  }

  .fsb__dropdown-option-title {
    font-weight: 500;
    margin: 0;
    color: var(--fs-color);
  }

  .fsb__dropdown-option-price {
    font-size: 0.875rem;
    color: var(--fs-highlight-color);
    margin: 0;
  }
</style>

{%- capture placeholder -%}
  <div class="items-placeholder">
    <svg width="100%" viewBox="0 0 210 48" fill="none" xmlns="http://www.w3.org/2000/svg">
      <rect x="0.5" y="0.5" width="47" height="47" rx="3.5" stroke="#A9A9A9" stroke-dasharray="6 6" />
      <rect x="56.5" y="0.5" width="153" height="17" rx="1.5" stroke="#B1B1B1" stroke-dasharray="6 6" />
      <rect x="56.5" y="24.5" width="63" height="17" rx="1.5" stroke="#B1B1B1" stroke-dasharray="6 6" />
    </svg>... </div>
{%- endcapture -%}

{%- capture icon_caret -%}
  <svg class="icon icon-caret" width="16" viewBox="0 0 10 6">
    <path
      fill="currentColor"
      fill-rule="evenodd"
      d="M9.354.646a.5.5 0 0 0-.708 0L5 4.293 1.354.646a.5.5 0 0 0-.708.708l4 4a.5.5 0 0 0 .708 0l4-4a.5.5 0 0 0 0-.708"
      clip-rule="evenodd"
    />
  </svg>
{%- endcapture -%}

{%- capture icon_delete -%}
  <svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" class="icon-delete"><path d="M11.5001 8.25C11.9143 8.25 12.2501 8.58579 12.2501 9V13.25C12.2501 13.6642 11.9143 14 11.5001 14C11.0858 14 10.7501 13.6642 10.7501 13.25V9C10.7501 8.58579 11.0858 8.25 11.5001 8.25Z" fill="currentColor"/><path d="M9.25006 9C9.25006 8.58579 8.91427 8.25 8.50006 8.25C8.08585 8.25 7.75006 8.58579 7.75006 9V13.25C7.75006 13.6642 8.08585 14 8.50006 14C8.91427 14 9.25006 13.6642 9.25006 13.25V9Z" fill="currentColor"/><path fill-rule="evenodd" clip-rule="evenodd" d="M7.25 5.25C7.25 3.73122 8.48122 2.5 10 2.5C11.5188 2.5 12.75 3.73122 12.75 5.25H15.7501C16.1643 5.25 16.5001 5.58579 16.5001 6C16.5001 6.41421 16.1643 6.75 15.7501 6.75H15L14.9999 12.2001C14.9998 13.880  14.9998 14.7203 14.6728 15.362C14.3852 15.9265 13.9262 16.3854 13.3618 16.673C12.72 17 11.88 17 10.1998 17H9.80005C8.11984 17 7.27974 17 6.63799 16.673C6.07349 16.3854 5.61455 15.9264 5.32693 15.3619C4.99995 14.7202 4.99997 13.8801 5 12.1999L5.00011 6.75H4.25006C3.83585 6.75 3.50006 6.41421 3.50006 6C3.50006 5.58579 3.83585 5.25 4.25006 5.25H7.25ZM8.75 5.25C8.75 4.55964 9.30964 4 10 4C10.6904 4 11.25 4.55964 11.25 5.25H8.75ZM6.50013 6.75H13.5L13.4998 12.2001C13.4998 13.0649 13.4986 13.6233 13.4639 14.0483C13.4306 14.4558 13.3741 14.6068 13.3363 14.681C13.1925 14.9632 12.963 15.1927 12.6808 15.3365C12.6066 15.3743 12.4555 15.4308 12.048 15.4641C11.623 15.4988 11.0646 15.5 10.1998 15.5H9.80005C8.93519 15.5 8.37677 15.4988 7.95175 15.4641C7.54424 15.4308 7.39316 15.3743 7.31899 15.3365C7.03674 15.1927 6.80727 14.9632 6.66346 14.681C6.62567 14.6068 6.56916 14.4557 6.53587 14.0482C6.50115 13.6232 6.5 13.0648 6.50002 12.1999L6.50013 6.75Z" fill="currentColor"/></svg>
{%- endcapture -%}

{% capture bundle_options %}
  {% if product.variants > 1 %}
    <label for="" class="bundle-options-container-label">{{ section.settings.bundle_option_label }}</label>
  {% endif %}
  <fsb-bundleoptions class="bundle-options-container {% if product.has_only_default_variant == true %} hidden {% endif %}">
    {% if product.variants.size > threshold %}
      <fsb-popover class="fsb__popover">
        <button
          class="fsb__popover-trigger"
          aria-haspopup="true"
          aria-expanded="false">
          {{ section.settings.bundle_option_label }}
        </button>
        <div class="fsb__popover-content">
          {% for variant in product.variants %}
            {% assign variant_id = variant.id | append: "" %}
            {%- assign option = options | where: 'variant_id', variant_id | first -%}
            <div
              data-variant="{{ variant.inventory_quantity | json | escape }}"
              class="bundle-option"
              {% if default_variant_id == variant.id %}
              selected
              {% endif %}
              data-quantity="{{ option.quantity }}"
              data-option-id="{{ variant.id }}"
              data-option="{{ option | json | escape }}"
              data-strategy="{{ option.price.strategy }}"
              data-price="{{ option.price.value }}">
              <span>{{ variant.title }}</span>
              {% if option.price.strategy == "dynamic_pricing" %}
                <span class="bundle-option-percentage">
                  {{ option.price.value | replace: ".0", "" }}{{ section.settings.percentage_discount_suffix }}
                </span>
              {% else %}  
                <span class="bundle-option-money">
                  {{ option.price.value |  times: 100 | money_without_trailing_zeros }}
                </span>
              {% endif %}
            </div>
          {% endfor %}
        </div>
      </fsb-popover>
    {% else %}
      {%- for variant in product.variants -%}
        {% assign variant_id = variant.id | append: "" %}
        {%- assign option = options | where: 'variant_id', variant_id | first -%}
        <div
          data-variant="{{ variant.inventory_quantity | json | escape }}"
          class="bundle-option bundle-option_swatch"
          {% if default_variant_id == variant.id %}
          selected
          {% endif %}
          data-quantity="{{ option.quantity }}"
          data-option-id="{{ variant.id }}"
          data-option="{{ option | json | escape }}"
          data-strategy="{{ option.price.strategy }}"
          data-price="{{ option.price.value }}">
          <span>{{ variant.title }}</span>
          {% if option.price.strategy == "dynamic_pricing" %}
            <span class="bundle-option-percentage">
              {{ option.price.value | replace: ".0", "" }}{{ section.settings.percentage_discount_suffix }}
            </span>
          {% else %}  
            <span class="bundle-option-money">
              {{ option.price.value |  times: 100 | money_without_trailing_zeros }}
            </span>
          {% endif %}
        </div>
      {% endfor %}
    {% endif %}
  </fsb-bundleoptions>
{% endcapture %}

{% if dynamic_add_ons_bundle_config.bundle_id %}
  
    <input type="hidden" name="bundle_id" value="{{ dynamic_add_ons_bundle_config.bundle_id }}">
    <input type="hidden" name="bundle_options" value="{{ options | json | escape }}">
    <input type="hidden" name="bundle_products" value="{{ products | json | escape }}">
    <input type="hidden" name="bundle_categories" value="{{ categories | json | escape }}">
    <input type="hidden" name="section_id" value="{{ section_id }}">
  <div class="fsb fsb-wrapper">
    <div class="page-width">
      {% comment %} <div class="fsb__mobile-only">{{ section.settings.select_your_box }}</div> {% endcomment %}
      <div class="fsb__bundle fsb__bundle--mobile">
        {{ bundle_options }}
      </div>
      
      <fsb-tabs class="fsb__tabs">
        <div class="fsb__inner-container">
          <!-- Replace grid with dropdown selector -->
          <div class="fsb__dropdown-selector {% if as_card %}{% endif %}">
            {% for category in categories %}
              <fsb-tab
                data-category-name="{{ category.title }}"
                data-category-limit="{{ category.quantity }}"
                title="{{ category.title }}"
                class="tabs__content-item active"
                id="tab{{ forloop.index }}"
              > 
              <div class="bundle-selection">
                <h2>{{ section.settings.select_heading }}</h2>  
              
                <!-- Dropdown Group -->
                <fsb-dropdown-group class="fsb__dropdown-group bundle-select-wrap sample-bundle-select-wrap">
                  <!-- Dropdown 1 -->
                  <div class="fsb__dropdown-item">
                    <fsb-product-dropdown class="select-option-wrap" data-dropdown-index="0">
                      <select class="fsb__dropdown-select" data-dropdown="0">
                        <option value="">Select Sample 1</option>
                        {% for p in category.products %}
                          {% liquid
                            assign int_product_id = p.id | times: 1
                            paginate products by 128
                              for ref in products
                                if ref.id == int_product_id
                                  assign card_product = ref
                                  break
                                endif
                              endfor
                            endpaginate
                          %}
                          {% for variant in card_product.variants %}
                            {% if variant.available %}
                              <option value="{{ variant.id }}" 
                                      data-product-id="{{ card_product.id }}"
                                      data-product-title="{{ card_product.title }}"
                                      data-variant-title="{% if variant.title != 'Default Title' %}{{ variant.title }}{% endif %}"
                                      data-price="{{ variant.price }}"
                                      data-image="{% if variant.featured_image %}{{ variant.featured_image | image_url: width: 50 }}{% else %}{{ card_product.featured_image | image_url: width: 50 }}{% endif %}">
                                {{ card_product.title }}{% if variant.title != 'Default Title' %} - {{ variant.title }}{% endif %}
                              </option>
                            {% endif %}
                          {% endfor %}
                        {% endfor %}
                      </select>
                    </fsb-product-dropdown>
                  </div>

                  <!-- Dropdown 2 -->
                  <div class="fsb__dropdown-item">
                    <fsb-product-dropdown class="select-option-wrap" data-dropdown-index="1">
                      <select class="fsb__dropdown-select" data-dropdown="1">
                        <option value="">Select Sample 2</option>
                        {% for p in category.products %}
                          {% liquid
                            assign int_product_id = p.id | times: 1
                            paginate products by 128
                              for ref in products
                                if ref.id == int_product_id
                                  assign card_product = ref
                                  break
                                endif
                              endfor
                            endpaginate
                          %}
                          {% for variant in card_product.variants %}
                            {% if variant.available %}
                              <option value="{{ variant.id }}" 
                                      data-product-id="{{ card_product.id }}"
                                      data-product-title="{{ card_product.title }}"
                                      data-variant-title="{% if variant.title != 'Default Title' %}{{ variant.title }}{% endif %}"
                                      data-price="{{ variant.price }}"
                                      data-image="{% if variant.featured_image %}{{ variant.featured_image | image_url: width: 50 }}{% else %}{{ card_product.featured_image | image_url: width: 50 }}{% endif %}">
                                {{ card_product.title }}{% if variant.title != 'Default Title' %} - {{ variant.title }}{% endif %}
                              </option>
                            {% endif %}
                          {% endfor %}
                        {% endfor %}
                      </select>
                    </fsb-product-dropdown>
                  </div>

                  <!-- Dropdown 3 -->
                  <div class="fsb__dropdown-item">
                    <fsb-product-dropdown class="select-option-wrap" data-dropdown-index="2">
                      <select class="fsb__dropdown-select" data-dropdown="2">
                        <option value="">Select Sample 3</option>
                        {% for p in category.products %}
                          {% liquid
                            assign int_product_id = p.id | times: 1
                            paginate products by 128
                              for ref in products
                                if ref.id == int_product_id
                                  assign card_product = ref
                                  break
                                endif
                              endfor
                            endpaginate
                          %}
                          {% for variant in card_product.variants %}
                            {% if variant.available %}
                              <option value="{{ variant.id }}" 
                                      data-product-id="{{ card_product.id }}"
                                      data-product-title="{{ card_product.title }}"
                                      data-variant-title="{% if variant.title != 'Default Title' %}{{ variant.title }}{% endif %}"
                                      data-price="{{ variant.price }}"
                                      data-image="{% if variant.featured_image %}{{ variant.featured_image | image_url: width: 50 }}{% else %}{{ card_product.featured_image | image_url: width: 50 }}{% endif %}">
                                {{ card_product.title }}{% if variant.title != 'Default Title' %} - {{ variant.title }}{% endif %}
                              </option>
                            {% endif %}
                          {% endfor %}
                        {% endfor %}
                      </select>
                    </fsb-product-dropdown>
                  </div>
                 
                </fsb-dropdown-group>
              </div>
              </fsb-tab>
            {% endfor %}
          </div>
          
          <div style="margin: 0 auto;" class="add-to-cart"> 
            <div class="add-to-cart__qty">
              <div class="qty">
                <label for="qtyInput" class="visually-hidden">Quantity</label>
                <input id="qtyInput" class="qty__input js-qtyInput" type="text" name="quantity" value="1" readonly>
                <button class="qty__btn qty__minus js-qtyMinus" disabled>
                  <span class="visually-hidden">Decrease quantity</span>
                  <svg class="icon-minus" viewBox="0 0 9 9">
                    <use xmlns:xlink="http://www.w3.org/1999/xlink" xlink:href="#icon-minus"></use>
                  </svg>
                </button>
                <button class="qty__btn qty__plus js-qtyPlus">
                  <span class="visually-hidden">Increase quantity</span>
                  <svg class="icon-plus" viewBox="0 0 9 9">
                    <use xmlns:xlink="http://www.w3.org/1999/xlink" xlink:href="#icon-plus"></use>
                  </svg>
                </button>
              </div>
            </div>
            <button style="margin: 1rem auto;" class="button js-addToCart" data-bundle-id="{{ bundle_id }}" data-id="{{ default_variant_id }}" disabled>
              {{ section.settings.add_to_cart_button }}
            </button>
          </div>
          

          <!-- Keep the sidebar as is -->
         
        </div>
      </fsb-tabs>
    </div>
  </div>
  

  <script>
      const fsMoneyFormat = {{ currency_format | json }};
      const fsbAdditionalSettings = {
        redirect_to_cart: false,
        show_popup: true,
        auto_advance_bundle: true,
        custom_cart_event: '',
      };
      const bundleId = "{{ bundle_id }}";
      window.fsbSettings = {
        show_personalization: {{ section.settings.show_personalization | json }},
        personalization_title: {{ section.settings.personalization_title | json }},
        personalization_placeholder: {{ section.settings.personalization_placeholder | json }},
        personalization_char: {{ section.settings.personalization_char }},
        personalization_char_limit: {{ section.settings.personalization_char_limit | json }},
        personalization_cancel: {{ section.settings.personalization_cancel | json }},
        personalization_add: {{ section.settings.personalization_add | json }},
        personalization_max_error: {{ section.settings.personalization_max_error | json }},
        personalization_property_name: {{ section.settings.personalization_property_name | json }},
        view_message_button_text: {{ section.settings.view_message_button_text | json }},
        randomize_notification: {{ section.settings.randomize_notification | json }},

        bundle_option_label: {{ section.settings.bundle_option_label | json }},
        percentage_discount_suffix: {{ section.settings.percentage_discount_suffix | json }},
        bundle_selection_count_text: {{ section.settings.bundle_selection_count_text | json }},

        addon_heading: {{ section.settings.addon_heading | json }},
        addons_text: {{ section.settings.addons_text | json }},
        addons_text_different: {{ section.settings.addons_text_different | json }},
        free_label: {{ section.settings.free_label | json }},

        next_button: {{ section.settings.next_button | json }},
        back_button: {{ section.settings.back_button | json }},
        add_to_cart_button: {{ section.settings.add_to_cart_button | json }},
        atk_label: {{ section.settings.atk_label | json }},
        blank_button_label: {{ section.settings.blank_button_label | json }},
        {% comment %} added_toast_message: {{ section.settings.added_toast_message | json }}, {% endcomment %}

        quantity_text: {{ section.settings.quantity_text | json }},
        quantity_text_plural: {{ section.settings.quantity_text_plural | json }},

        all_label: {{ section.settings.all_label | json }},
        show_all_tab: {{ section.settings.show_all_tab | json }},

        columns_desktop: {{ section.settings.columns_desktop | json }},
        columns_mobile: {{ section.settings.columns_mobile | json }},

        section_background: {{ section.settings.section_background | json }},
        cards_background: {{ section.settings.cards_background | json }},
        text_color: {{ section.settings.text_color | json }},
        highlight_color: {{ section.settings.highlight_color | json }},
        highlight_text_color: {{ section.settings.highlight_text_color | json }},
        highlight_color_2: {{ section.settings.highlight_color_2 | json }},
        highlight_text_color_2: {{ section.settings.highlight_text_color_2 | json }},

        variant_selector_label: {{ section.settings.variant_selector_label | json }},
        hide_single_variant_selector: {{ section.settings.hide_single_variant_selector | json }},
        hide_unavailable_products: {{ section.settings.hide_unavailable_products | json }},
        split_option: {{ section.settings.split_option | json }},
        color_swatch_options: {{ section.settings.color_swatch_options | json }},
        color_swatch_config: {{ section.settings.color_swatch_config | json }}
      };
  </script>
{% endif %}

{% endif %}

{% schema %}
{
  "name": "Foxsell - Mix & Match",
  "settings": [
    {
      "type": "text",
      "id": "select_heading",
      "label": "Select Heading",
      "default": "Please Make Your Selection"
    },
    { "type": "header", "content": "Basic Configuration" },
    { "type": "product", "id": "product", "label": "Parent Bundle Product" },
    { "type": "header", "content": "Tab Settings" },
    {
      "type": "checkbox",
      "id": "show_all_tab",
      "default": true,
      "label": "Enable 'All Products' Tab",
      "info": "Shows all bundle-eligible products in a single tab view"
    },
    {
      "type": "text",
      "id": "all_label",
      "label": "'All' tab label",
      "default": "All",
      "visible_if": "{{ section.settings.show_all_tab }}"
    },
    { "type": "header", "content": "Products Grid" },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 3,
      "label": "Desktop Grid Columns",
      "info": "Number of products displayed per row on desktop screens"
    },
    {
      "type": "range",
      "id": "columns_mobile",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 2,
      "label": "Products per Row mobile"
    },
    { "type": "header", "content": "Variant Selection" },
    {
      "type": "text",
      "id": "variant_selector_label",
      "label": "Variant selector label",
      "default": "Select [option]",
      "info": "Label for variant dropdowns. Example: '[option]' becomes 'Select Size' or 'Select Color'"
    },
    {
      "type": "checkbox",
      "id": "hide_single_variant_selector",
      "label": "Hide variant selector for single variant products",
      "default": false,
      "info": "When enabled, hides the variant selector for products with only one available variant"
    },
    {
      "type": "checkbox",
      "id": "hide_unavailable_products",
      "label": "Hide unavailable products",
      "default": true,
      "info": "When enabled, hides products that have no available variants from the bundle builder"
    },
    { "type": "header", "content": "Button Settings" },
    {
      "type": "text",
      "id": "atk_label",
      "label": "Add to Bundle label",
      "default": "Add"
    },
    {
      "type": "text",
      "id": "atk_class",
      "label": "Add to Bundle custom classes",
      "info": "Add your theme's CSS class to add to cart button for style customization"
    },
    {
      "type": "text",
      "id": "blank_button_label",
      "label": "Unselected Add to Bundle label",
      "info": "Label when valid variant is not selected",
      "default": "Unavailable"
    },
    {
