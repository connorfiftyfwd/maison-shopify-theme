<div class="page-width section-{{ section.id }}-padding">
	<div class="flex flex--{{ section.id }}">

		<div class="image-wrapper">
			{% if section.settings.side_image != blank %}
				{{ section.settings.side_image | image_url: width: 500 | image_tag: width: 500, class: 'image_by_side', alt: section.settings.side_image }}
			{% endif %}
		</div>

		<div class="text_wrapper">
			{% for block in section.blocks %}
				{% case block.type %}
					{% when 'heading' %}
						<h2 class="image_with_text__heading">{{ block.settings.heading }}</h2>
					{% when 'content' %}
						{% if block.settings.content != blank %}
							<div class="content_container">{{ block.settings.content }}</div>
						{% endif %}
				{% endcase %}
			{% endfor %}
		</div>
	</div>
</div>

<style>
	.flex--{{ section.id }} {
		display: flex;
		flex-direction: {{ section.settings.mobile_layout }}
	}
	.section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
	
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
		.flex--{{ section.id }} {
			flex-direction: {{ section.settings.desktop_layout }};
			justify-content: space-between;
		}
  }
</style>

{% schema %}
{
  "name": "Image with text",
  "class": "image-with-text",
  "settings": [
    {
      "type": "select",
      "id": "mobile_layout",
      "label": "Mobile Layout",
      "options": [
        {
          "value": "column-reverse",
          "label": "Text First"
        },
        {
          "value": "column",
          "label": "Image first"
        }
      ],
      "default": "column-reverse"
    },
    {
      "type": "select",
      "id": "desktop_layout",
      "label": "Desktop layout",
      "options": [
        {
          "label": "Text first",
          "value": "row-reverse"
        },
        {
          "value": "row",
          "label": "Image first"
        }
      ],
      "default": "row-reverse"
    },
    {
      "type": "image_picker",
      "id": "side_image",
      "label": "Side image"
    },
    {
      "type": "header",
      "content": "Padding section"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "name": "Heading",
      "type": "heading",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "heading",
          "label": "Heading"
        }
      ]
    },
    {
      "name": "Content",
      "type": "content",
      "settings": [
        {
          "type": "richtext",
          "id": "content",
          "label": "Content"
        }
      ]
    }
  ]
}
{% endschema %}