{% schema %}
{
  "name": "Shipping",
  "settings": [
    {
      "id": "heading",
      "type": "text",
      "label": "Heading for Desktop"
    },
    {
      "id": "headingMobile",
      "type": "text",
      "label": "Heading for Mobile",
      "info": "If different from the desktop"
    },
    {
      "id": "content",
      "type": "richtext",
      "label": "Content"
    },
    {
      "type": "checkbox",
      "id": "isShippingEnable",
      "label": "Enable",
      "default": true
    }
  ]
}
{% endschema %}

{% if section.settings.isShippingEnable %}
  {%- assign hash = section.settings.heading | downcase | handleize -%}
  {% render 'utility-content'
    content: section.settings.content
    hash: hash
    heading: section.settings.heading
    headingMobile: section.settings.headingMobile
  %}
{% endif %}
