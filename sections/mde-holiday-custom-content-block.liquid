{%- capture customContent -%}
{% assign secSt = section.settings %}
<div class="sec_cov mde-section-{{ section.id }}{% if secSt.hidem %} hide-sm{% endif %}{% if secSt.hided %} hide-md hide-lg{% endif %}" style="--sbg:{% if secSt.bgg != blank %}{{ secSt.bgg }}{% else %}{{ secSt.bg }}{% endif %};--sst:{{ secSt.sst }}px;--ssb:{{ secSt.ssb }}px;--sstm:{{ secSt.sstm }}px;--ssbm:{{ secSt.ssbm }}px">  
    <div class="page-width fullwidth custom-block {{section.settings.style }}">  
        {%- if section.settings.title != blank or section.settings.subtitle != blank -%}
        <div class="sec-ttl{% if section.settings.section_title_align != "default" %} {{ section.settings.section_title_align }}{% else %} {{ settings.title_align }}{% endif %}">
          {%- if section.settings.title != blank -%}
            <h2 class="sttl"{% if section.settings.change_title_text_color %} style="color:{{ section.settings.title_text_color }};"{% endif %}><span class="dbi pr">{{ section.settings.title }}</span></h2>
            {%- if section.settings.subtitle != blank -%}<div class="sbttl"{% if section.settings.change_subtitle_text_color %}{%- endif -%} style="color:{{ section.settings.subtitle_text_color }};"{% endif %}>{{ section.settings.subtitle }}</div>{%- endif -%}
        </div>
        {%- endif -%}
        <div class="grid custom-cnt gspace" style="--grsp:0 -{{ section.settings.gspace | divided_by: 2.0 }}px;--grspi:0 {{ section.settings.gspace | divided_by: 2.0 }}px {{ section.settings.gspace }}px;--grspm:0 -{{ section.settings.gspacem | divided_by: 2.0 }}px;--grspim:0 {{ section.settings.gspacem | divided_by: 2.0 }}px {{ section.settings.gspacem }}px;">
                {% for block in section.blocks %}
                    {% assign blkSt = block.settings %}
                    <div class="gitem ct_item cti{{ block.id }} {{ blkSt.width }}-md {{ blkSt.alignment }}{% if block.type == "text" or block.type == "image" or block.type == "product" %} page-width-content{% endif %}{% if blkSt.hidem %} hide-sm{% endif %}" {{ block.shopify_attributes }}>
                        <div class="of_hidden ct_item_in ct_item_{{ block.type }} w_100" style="--bg:{{ blkSt.clbg }};--brad:{{ blkSt.brad }}px;">                           
                        {% case block.type %}
                            {% when 'hero' %}
                            <div class="cti{{ block.id }}">
                              <div class="hero-section">
                                {% assign desktop_image = block.settings.image %}
                                {% assign mobile_image = block.settings.imagem %}
                                {% assign overlay_color = block.settings.ovr %}
                                {% assign overlay_opacity = block.settings.ovropt %}
                                {% assign text_position = block.settings.txtpos %}
                            
                                <div class="hero-wrapper">
                                  <div class="hero-overlay" style="background-color: {{ overlay_color }}; opacity: {{ overlay_opacity }};"></div>
                                  <div class="hero-content {{ text_position }}">
                                    {% if block.settings.title != blank %}
                                      <h1 class="hero-title" style="
                                        color: {{ block.settings.tcl }};
                                        font-size: {{ block.settings.tfs }}px;
                                        font-weight: {{ block.settings.tfw }};
                                        opacity: {{ block.settings.to }};
                                        line-height: {{ block.settings.tlh }};
                                        margin-bottom: {{ block.settings.tmb }}px;
                                      ">{{ block.settings.title | escape }}</h1>
                                    {% endif %}
                            
                                    {% if block.settings.hd3 != blank %}
                                      {% unless block.settings.hideh3 %}
                                        <p class="hero-detail" style="
                                          color: {{ block.settings.cl }};
                                          font-size: {{ block.settings.fs }}px;
                                          font-weight: {{ block.settings.fw }};
                                          line-height: {{ block.settings.lh }};
                                          margin-bottom: {{ block.settings.mb }}px;
                                        ">{{ block.settings.hd3 | escape }}</p>
                                      {% endunless %}
                                    {% endif %}
                                  </div>
                                </div>
                              </div>
                            
                              <style>
                                .cti{{ block.id }} .hero-section {
                                  height: {{ block.settings.htd }}px;
                                  background-image: url({{ desktop_image | img_url: '2000x' }}); /* Default to desktop image */
                                  background-size: cover;
                                  background-position: center;
                                  background-repeat: no-repeat;
                                }
                            
                                @media (max-width: 1024px) {
                                  .cti{{ block.id }} .hero-section {
                                    height: {{ block.settings.htt }}px;
                                    {% if mobile_image != blank %}background-image: url({{ mobile_image | img_url: '800x' }});{% endif %}
                                  }
                                }
                            
                                @media (max-width: 768px) {
                                  .cti{{ block.id }} .hero-section {
                                    height: {{ block.settings.htm }}px;
                                  }
                            
                                  .cti{{ block.id }} .hero-content {
                                    width: 100%;
                                    padding: 0 15px;
                                  }
                                }
                              </style>
                            </div>
                            
                            {% when 'image' %}
                                {% if blkSt.image != blank %}
                                    {% if blkSt.imgurl != blank %}<a href="{{ blkSt.imgurl }}">{% endif %}
                                    <div class="imgWrapper" style="max-width:{% if blkSt.adjust_img %}{{ blkSt.image_width }}{% else %}{{ blkSt.image.width }}{% endif %}px;--brad:{{ blkSt.brad }}px;">
                                        
                                        {% assign crop_location = block.settings.image_crop_location | default: 'center' %}
                                        
                                        {% if block.settings.image_crop == 'square' %}
                                            <!-- Square image crop -->
                                            <img class="imgFl ctimg wow zoomIn" 
                                                 src="{{ blkSt.image | img_url: '800x800', crop: crop_location }}" 
                                                 width="800" 
                                                 height="800"
                                                 data-srcset="{{ blkSt.image | img_url: '800x800', crop: crop_location }} 800w, {{ blkSt.image | img_url: '1600x1600', crop: crop_location }} 1600w, {{ blkSt.image | img_url: 'master', crop: crop_location }}" 
                                                 data-sizes="auto" 
                                                 alt="{{ blkSt.image.alt | escape }}">
                                        
                                        {% elsif block.settings.image_crop == 'portrait' %}
                                            <!-- Portrait image crop -->
                                            <img class="imgFl ctimg wow zoomIn" 
                                                 src="{{ blkSt.image | img_url: '800x1200', crop: crop_location }}" 
                                                 width="800" 
                                                 height="1200"
                                                 data-srcset="{{ blkSt.image | img_url: '800x1200', crop: crop_location }} 800w, {{ blkSt.image | img_url: '1600x2400', crop: crop_location }} 1600w, {{ blkSt.image | img_url: 'master', crop: crop_location }}" 
                                                 data-sizes="auto" 
                                                 alt="{{ blkSt.image.alt | escape }}">
                                
                                        {% else %}
                                            <!-- Default image handling (untouched original code) -->
                                            <img class="imgFl ctimg wow zoomIn" 
                                                 src="{{ blkSt.image | img_url: '1200x' }}" 
                                                 width="{{ blkSt.image.width }}" 
                                                 height="{{ blkSt.image.height }}"
                                                 data-srcset="{{ blkSt.image | img_url: '1200x' }}" 
                                                 data-sizes="auto" 
                                                 alt="{{ blkSt.image.alt | escape }}">
                                        {% endif %}
                                        
                                    </div>
                                    {% if blkSt.imgurl != blank %}</a>{% endif %}
                                {% else %}
                                    {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                                {% endif %}
                            {% when 'text' %}								
                                <div class="{{ blkSt.align_text }}" style="--ttcl:{{ blkSt.cl }};--ttfs:{{ blkSt.fs }}px;--ttfsm:{{ blkSt.fsm }}px;--ttfw:{{ blkSt.fw }};--ttlh:{{blkSt.lh }}">
                                    {% if blkSt.img_position == "above" %}
                                    {% if blkSt.dis_img %}
                                    {% if blkSt.image != blank  %}
                                        {% if blkSt.btnurl != blank %}<a href="{{ blkSt.btnurl }}">{% endif %}
                                            <div class="imgWrapper" style="max-width:{% if blkSt.adjust_img %}{{ blkSt.image_width }}{% else %}{{ blkSt.image.width }}{% endif %}px;--brad:{{ blkSt.brad }}px;margin-bottom:15px;"">
                                              
                                              {% assign crop_location = block.settings.image_crop_location | default: 'center' %}
                                                {% if block.settings.image_crop == 'square' %}
                                                    <!-- Square image crop -->
                                                    <img class="imgFl ctimg wow zoomIn" 
                                                         src="{{ blkSt.image | img_url: '800x800', crop: crop_location }}" 
                                                         width="800" 
                                                         height="800"
                                                         alt="{{ blkSt.image.alt | escape }}">
                                                
                                                {% elsif block.settings.image_crop == 'portrait' %}
                                                    <!-- Portrait image crop -->
                                                    <img class="imgFl ctimg wow zoomIn" 
                                                         src="{{ blkSt.image | img_url: '800x1200', crop: crop_location }}" 
                                                         width="800" 
                                                         height="1200"
                                                         alt="{{ blkSt.image.alt | escape }}">
                                                
                                                {% else %}
                                                    <!-- Default image handling (untouched original code) -->
                                                    <img class="imgFl ctimg wow zoomIn" 
                                                       src="{{ blkSt.image | img_url: '1200x' }}" 
                                                       width="{{ blkSt.image.width }}" 
                                                       height="{{ blkSt.image.height }}"
                                                       data-srcset="{{ blkSt.image | img_url: '1200x' }}" 
                                                       data-sizes="auto" 
                                                       alt="{{ blkSt.image.alt | escape }}">
                                                {% endif %}
                                            </div>
                                        {% if blkSt.btnurl != blank %}</a>{% endif %}
                                    {% else %}
                                     <p> {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}</p>
                                    {% endif %}
                                    {% endif %}
                                    {% endif %}
                                    <div class="custom-text">
                                        {% if blkSt.title != blank %}<h3 class="ttlTxt" style="margin-bottom:{{ blkSt.tbm }}px;{% if blkSt.all_caps_heading %}text-transform:uppercase;{% endif %}{% if blkSt.adjust_text_ls %}letter-spacing:{{ blkSt.text_ls }}px{% endif %}">{{ blkSt.title }}</h3>{% endif %}
                                        {% if blkSt.text != blank %}<div class="rgTxt rte-setting mb20" style="--cl:{{ blkSt.cl }};">{{ blkSt.text }}</div>{% endif %}
                                        {% if blkSt.btntxt != blank and blkSt.btnurl != blank %}
                                            <a class="btn mb20 {{ blkSt.btn-size }} {{ blkSt.btn-style }}" href="{{ blkSt.btnurl }}">{{ blkSt.btntxt }}</a>
                                        {% endif %}
                                    </div>
                                    {% if blkSt.img_position == "below" %}
                                    {% if blkSt.dis_img %}
                                    {% if blkSt.image != blank  %}
                                        {% if blkSt.btnurl != blank %}<a href="{{ blkSt.btnurl }}">{% endif %}
                                            <div class="imgWrapper" style="max-width:{% if blkSt.adjust_img %}{{ blkSt.image_width }}{% else %}{{ blkSt.image.width }}{% endif %}px;--brad:{{ blkSt.brad }}px;margin-top:15px;">
                                              {% assign crop_location = block.settings.image_crop_location | default: 'center' %}
                                                {% if block.settings.image_crop == 'square' %}
                                                    <!-- Square image crop -->
                                                    <img class="imgFl ctimg wow zoomIn" 
                                                         src="{{ blkSt.image | img_url: '800x800', crop: crop_location }}" 
                                                         width="800" 
                                                         height="800"
                                                         alt="{{ blkSt.image.alt | escape }}">
                                                
                                                {% elsif block.settings.image_crop == 'portrait' %}
                                                    <!-- Portrait image crop -->
                                                    <img class="imgFl ctimg wow zoomIn" 
                                                         src="{{ blkSt.image | img_url: '800x1200', crop: crop_location }}" 
                                                         width="800" 
                                                         height="1200"
                                                         alt="{{ blkSt.image.alt | escape }}">
                                                
                                                {% else %}
                                                    <!-- Default image handling (untouched original code) -->
                                                    <img class="imgFl ctimg wow zoomIn" 
                                                       src="{{ blkSt.image | img_url: '1200x' }}" 
                                                       width="{{ blkSt.image.width }}" 
                                                       height="{{ blkSt.image.height }}"
                                                       data-srcset="{{ blkSt.image | img_url: '1200x' }}" 
                                                       data-sizes="auto" 
                                                       alt="{{ blkSt.image.alt | escape }}">
                                                {% endif %}
                                            </div>
                                        {% if blkSt.btnurl != blank %}</a>{% endif %}
                                    {% else %}
                                     <div class="imgWrapper" style="max-width:{% if blkSt.adjust_img %}{{ blkSt.image_width }}{% else %}{{ blkSt.image.width }}{% endif %}px;--brad:{{ blkSt.brad }}px;margin-top:15px;">{{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}</div>
                                    {% endif %}
                                    {% endif %}
                                    {% endif %}
                                    <style>                                       
                                        {% if blkSt.bg %}    										      
                                        .cti{{ block.id }} { align-self:stretch; display:flex;} 
                                        .cti{{ block.id }} .ct_item_in {display: flex; align-items: center; padding:35px;  background:{{ blkSt.clbg }}; border-radius:{{blkSt.boxrad}}px;}     
                                        .cti{{ block.id }}.f-ass .ct_item_in {align-items: start; }
                                        .cti{{ block.id }}.f-ase .ct_item_in {align-items: end;}  
                                        .cti{{ block.id }} .ct_item_in > div { width:100%;} 
                                        {% endif %}
                                          
                                        {% if block.settings.text_override == true %}
                                        .cti{{ block.id }} .rte-setting * {font-size:{{ block.settings.text_fs }}px;font-weight:{{ block.settings.text_fw }};line-height:{{ block.settings.text_lh }};{% if block.settings.text_override_family != "default" %}font-family:var(--{{ block.settings.text_override_family}});{% endif %}}
                                        @media only screen and (max-width:767px){.cti{{ block.id }} .rte-setting * {font-size:{{ block.settings.text_fsm }}px;}}	
                                        {% endif %} 
                                        {% if blkSt.adjust_maxwd %}@media only screen and (min-width: 1024px) {.cti{{ block.id }} .custom-text{ max-width:{{ blkSt.maxwd }}%;margin:0 auto;}}{% endif %}
                                        {% if blkSt.add_divider %}
                                        {% if blkSt.divider_location == "above" or blkSt.divider_location == "both" %}
                                        .cti{{ block.id }} .custom-text:before {content: "";position: relative;display: block;border-top: 1px solid {{ blkSt.divider_color }};margin: 15px 0;}
                                        {% endif %}
                                        {% if blkSt.divider_location == "below" or blkSt.divider_location == "both" %}
                                        .cti{{ block.id }} .custom-text:after {content: "";position: relative;display: block;border-top: 1px solid {{ blkSt.divider_color }};margin: 15px 0;}
                                        {% endif %}
                                        {% endif %}     	
                                    </style>             
                                </div>                                                  
                            
                            {% when 'product' %}
                            <div class="product-section product-section-{{ block.id }}">
                              {% assign image = block.settings.image %}
                              {% assign image_location = block.settings.image_location %}
                              {% assign collection = collections[block.settings.collection_handle] %}
                              
                              <div class="product-layout {% if image_location == 'right' %}reverse{% endif %}">
                                {% if image != blank %}
                                  <div class="large-image">
                                    <picture>
                                      <source media="(max-width: 1023px)" srcset="{{ image | image_url: width: 800 }}">
                                      {% if blkSt.imgurl != blank %}
                                        <a href="{{ blkSt.imgurl }}">
                                      {% endif %}
                                        <img src="{{ image | image_url: width: 1600 }}" alt="Large image" class="large-product-image" />
                                      {% if blkSt.imgurl != blank %}
                                        </a>
                                      {% endif %}
                                    </picture>
                                
                                    {% if blkSt.imgurl != blank %}
                                      <a href="{{ blkSt.imgurl }}" class="image-overlay-link"></a>
                                    {% endif %}
                                  </div>
                                
                                  <style>
                                  @media screen and (min-width: 1024px) {
                                    .product-section-{{ block.id }} .large-image {
                                      width: calc(50% - 0.5px);
                                      flex-shrink: 0; 
                                      background-size: cover; 
                                      background-position: center; 
                                      background-repeat: no-repeat;
                                      background-image: url('{{ image | image_url: width: 1600 }}');
                                      position: relative;
                                    }
                                    
                                    .image-overlay-link {
                                      position: absolute;
                                      top: 0;
                                      left: 0;
                                      width: 100%;
                                      height: 100%;
                                      display: block;
                                      z-index: 10;
                                    }
                                  }
                                  </style>
                                {% endif %}
                              
                                {% if collection != blank and collection.products.size > 0 %}
                                  <div class="plp__items">
                                    {% for product in collection.products %}
                                      <div class="plp__item">
                                        {% render 'plp-product', product: product, rx_position: forloop.index, block: block.settings %}
                                      </div>
                                    {% endfor %}
                                  </div>
                                {% else %}
                                  <p>No products found in the selected collection.</p>
                                {% endif %}
                              </div>
                              
                              {% if block.settings.link_text != blank and block.settings.link_url != blank %}
                              <div class="product-link" style="text-align: {{ block.settings.link_position }};">
                                <a href="{{ block.settings.link_url }}" class="custom-link">{{ block.settings.link_text }}</a>
                              </div>
                              {% endif %}
                            </div>
                        
                            {% endcase %}
                        </div>
                    </div>
                {% endfor %}
            </div>
        </div>  
</div>
{% if secSt.change_title_size == true or secSt.change_subtitle_size == true %}
<style>
  {% if secSt.change_title_size == true %}.mde-section-{{ section.id }} .sec-ttl {{ settings.sttltag }} {font-size: {{ secSt.title_ts_mb }}px;}{% endif %}
  {% if secSt.change_subtitle_size == true %}.mde-section-{{ section.id }} .sbttl {font-size: {{ secSt.subtitle_ts_mb }}px;}{% endif %}
  {% if secSt.change_title_size == true or secSt.change_subtitle_size == true %}
  @media only screen and (min-width:768px){
   {% if secSt.change_title_size == true %}.mde-section-{{ section.id }} .sec-ttl {{ settings.sttltag }} {font-size: {{ secSt.title_ts }}px;}{% endif %}
   {% if secSt.change_subtitle_size == true %}.mde-section-{{ section.id }} .sbttl {font-size: {{ secSt.subtitle_ts }}px;}{% endif %}}
  {% endif %}
</style>
{% endif %}
{% render 'mde-head-css' %}

<style>
.mde-custom-section-block {
  font-family: PlantinMT,Times New Roman,serif;
}

.mde-custom-section-block .rte-setting * {
  font-family: GT America,Arial,sans-serif;
  letter-spacing: .5px;
}

.sec_cov { padding-top:var(--sstm); padding-bottom:var(--ssbm); background:var(--sbg); }
.sec-ttl {
  margin-bottom: 30px;
}
.sec-ttl h2 {
  margin-bottom: 10px;
}

.gitem.page-width-content {
  padding: 40px 40px;
}

@media only screen and (min-width:1025px){
    .gitem.page-width-content {
      padding: 40px 90px;
    }
}

@media only screen and (min-width:768px){  
  .sec_cov { padding-top:var(--sst); padding-bottom:var(--ssb);}	 
}
  {% comment %} /* Custom Block and Custom Template */ {% endcomment %}
  .ct_item .grid_bx { margin:0; }
  .ct_item .custom-text > *:last-child { margin-bottom:0; }
  .ct_item .custom-text a:not(.btn) { text-decoration:underline; }
  .ct_item .custom-text a:hover { text-decoration:none; }
    
  .ct_item_collection .details { position:absolute; left:15px; right:15px; text-align:center; bottom:15px; background-color:var(--bg);  border-radius:{{settings.btn_rad}}px;}
  @media only screen and (min-width:766px){
      .ct_item_collection .details { bottom:30px; left:50%; transform: translate(-50%); right:auto; }      
  }       
  @media only screen and (max-width:767px){ 
    .ct_item .custom-text br{ display: none;}
  }
  
  /* .gspace { margin:var(--grspm); }
  .gspace .gitem { padding:var(--grspim); }
  @media only screen and (min-width:768px) {
      .gspace { margin:var(--grsp); }
      .gspace .gitem { padding:var(--grspi); }
  } */
  
  .rte h1, .rte h2, .rte h3, .rte h4, .rte h5, .rte h6 { margin-top:15px; margin-bottom:7.5px }
  .rte h1:first-child, .rte h2:first-child, .rte h3:first-child, .rte h4:first-child, .rte h5:first-child, .rte h6:first-child { margin-top:0 }
  .rte li { margin-bottom:4px; list-style:inherit }
  .rte li:last-child { margin-bottom:0 }
  .rte blockquote { padding:30px; margin-bottom:20px }
  .rte img { height:auto }
  .rte table { table-layout:fixed }
  .rte ol, .rte ul { margin:{% if settings.rtl %}20px 30px 30px 0{% else %}20px 0 30px 15px{% endif %} }
  .rte ul { list-style:disc outside }
  .rte ul ul { list-style:circle outside }
  .rte ul ul ul { list-style:square outside }
  .rte a:not(.btn) { padding-bottom:1px }
  .tc .rte ol, .tc .rte ul, .tc.rte ol, .tc.rte ul { margin-left:0; list-style-position:inside }
  
  .product-section {
        width: 100%;
        max-width: 1280px;
        margin: 0 auto;
    }
  
  .product-layout {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  
  .large-image {
    width: 100%;
  }
  
  .large-product-image {
    width: 100%;
    height: auto;
  }
  
  .plp__items {
    width: 100%;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  
  .plp__item {
    width: calc(100% - 0px);
  }
  
  .product-layout.reverse .large-image {
    order: 1; 
  }
  
  .product-layout.reverse .plp__items {
    order: 2;
  }
  
  .plp-product__add-to-cart.tc {
    text-align: center;
  }
  
  @media screen and (min-width: 1024px) {
    .product-layout {
      flex-direction: row;
      gap: 2px;
      align-items: stretch;
    }
  
    .large-product-image {
      display: none;
    }
  
    .plp__items {
      width: calc(50% - 1px);
      display: flex;
      flex-wrap: wrap;
      gap: 2px;
    }
  
    .plp__item {
      width: calc(50% - 1px);
    }
  
    .product-layout.reverse .large-image {
      order: 2;
    }
  
    .product-layout.reverse .plp__items {
      order: 1;
    }
  }
  
  .product-link {
      margin-top: 60px;
  }
  
  .custom-link {
      position: relative;
      font-family: GT America,Arial,sans-serif;
      font-size: 12px;
      font-weight: 400;
      letter-spacing: .5px;
      text-decoration: none;
      display: inline-block;
      padding-bottom: 2px;
  }
  
  .custom-link::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      width: 0;
      height: 1px; 
      background-color: #626950;
      transition: width 0.3s ease; 
  }
  
  .custom-link:hover::after {
      width: 100%; 
  }
  
  
  .hero-section {
      position: relative;
      width: 100%;
      max-width: 2000px; /* Adjust as needed */
      margin: 0 auto;
      overflow: hidden;
      height: 700px; /* Default desktop height */
  }
  
  .hero-wrapper {
      position: relative;
      background-size: cover;
      background-position: center;
      width: 100%;
      height: 100%; /* Matches section height */
  }
  
  .hero-overlay {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
  }
  
  .hero-content {
      position: absolute;
      display: flex;
      flex-direction: column;
      text-align: left;
      margin: 0 15px;
  }
  
  .hero-content.f-ais-md.f-jcs-md { /* Top Left */
      top: 0;
      left: 0;
      align-items: flex-start;
      justify-content: flex-start;
  }
  
  .hero-content.f-jcc-md.f-ais-md { /* Top Center */
      top: 0;
      left: 50%;
      transform: translateX(-50%);
      align-items: center;
      justify-content: flex-start;
  }
  
