{% stylesheet %}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
	.content-rich-text--{{ section.id }} p {
    font-family: 'GT America', Arial, sans-serif;
    font-size: 12px;
    font-weight: 400;
    letter-spacing: .5px;
    line-height: 1.6;
    display: block;
    font-style: normal;
		-webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
    color: #626950;
}
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{% endstylesheet %}
<div class="page-width section-{{ section.id }}-padding">
  {% if section.settings.heading != blank %}
    <h2 class="rich-text__heading">{{ block.settings.heading }}</h2>
  {% endif %}
  {% if section.settings.content__rich-text != blank %}
    <div class="content-rich-text--{{ section.id }}">
      {{ section.settings.content__rich-text }}
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Rich text",
  "class": "rich-text",
  "tag": "section",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "content__rich-text",
      "label": "Content"
    },
    {
      "type": "header",
      "content": "Padding section"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 36
    }
  ]
}
{% endschema %}