<div class="add-to-cart">
  <div class="add-to-cart__inputs">
    {% if product.has_only_default_variant %}
      {% render 'fake-variant-selector' %}
    {% else %}
      {% if product.variants.size > 1 %}
        {% render 'variant-selector' %}
      {% endif %}
    {% endif %}
    <div class="add-to-cart__qty">
      <div class="qty">
        <label for="qtyInput" class="visually-hidden">Quantity</label>
        <input id="qtyInput" class="qty__input js-qtyInput" type="text" value="1" readonly>
        <button class="qty__btn qty__minus js-qtyMinus" disabled>
          <span class="visually-hidden">Decrease quantity</span>
          <svg class="icon-minus" viewBox="0 0 9 9">
            <use xmlns:xlink="http://www.w3.org/1999/xlink" xlink:href="#icon-minus"></use>
          </svg>
        </button>
        <button class="qty__btn qty__plus js-qtyPlus">
          <span class="visually-hidden">Increase quantity</span>
          <svg class="icon-plus" viewBox="0 0 9 9">
            <use xmlns:xlink="http://www.w3.org/1999/xlink" xlink:href="#icon-plus"></use>
          </svg>
        </button>
      </div>
    </div>
  </div>

  {% if product.selected_or_first_available_variant.available %}
     <button class="js-addToCart add-to-cart__btn button" data-id="{{ product.selected_or_first_available_variant.id }}">
        Add to Cart
      </button>
    {% comment %} {% if  product.selected_or_first_available_variant.id == 42617630064753 %}
      <button class="js-addToCart add-to-cart__btn  button" data-id="{{ product.selected_or_first_available_variant.id }}">
        Pre Order (Ships By 11/11/25)
      </button>
    {% else %}
      <button class="js-addToCart add-to-cart__btn button" data-id="{{ product.selected_or_first_available_variant.id }}">
        Add to Cart
      </button>
    {% endif %} {% endcomment %}
  {% else %}
    <button class="klaviyo add-to-cart__btn button">
      <a class="klaviyo-bis-trigger" href="#">Notify Me When Available</a>
    </button>
  {% endif %}
</div>

