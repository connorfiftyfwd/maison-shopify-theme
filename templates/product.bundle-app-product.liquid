<div class="product" data-view="product">
  <div class="product__slider product__panel js-slider slider js-mobileSlider js-productSlider" data-slider="pdp">
    {% for img in product.images %}
      {% if forloop.index > 1 %}
        <div class="product__image slide js-slide">
          {% assign alt = img.alt %}
          <picture>
            <source media="(max-width: 375px)"
                    srcset="{{ img | image_url: width: 375, height: 451 }} 1x, {{ img | image_url: width: 750, height: 902 }}"/>
            <source media="(min-width: 376px)"
                    srcset="{{ img | image_url: width: 700, height: 850 }} 1x, {{ img | image_url: width: 1400, height: 1700 }}"/>
            <source media="(min-width: 1024px)"
                    srcset="{{ img | image_url: width: 830, height: 1000 }} 1x, {{ img | image_url: width: 1660, height: 2000 }}"/>
            <img src="{{ img | image_url: width: 375, height: 451 }}" alt="{{ alt }}" class="is-loading" height="375" width="451" loading="eager">
          </picture>
        </div>
      {% endif %}
    {% endfor %}
  </div>
  <div class="product__details product__panel" itemscope itemtype="http://schema.org/Product">
    <h1 class="product__title" itemprop="name">
      {{ product.title }}
    </h1>
    <div class="product__price" itemscope itemtype="http://schema.org/Offer">
      <meta itemprop="priceCurrency" content="USD"/>
      <meta itemprop="price" content="{{ product.price | money_without_currency }}"/>
      <link itemprop="availability"
            href="{% if product.available %}http://schema.org/InStock{% else %}http://schema.org/OutOfStock{% endif %}"/>
      {% section 'bundle-product-samples3-price' %}
    </div>
    <div class="product__type">
      {{ product.type }}
      {% unless product.has_only_default_variant %}
        (&nbsp;℮&nbsp;<span
              class="js-variantTitle">{{ product.selected_or_first_available_variant.title }}</span>&nbsp;)
      {% endunless %}
    </div>
    <div class="product__description">
      {{ product.description }}
    </div>
    
    <!-- Include the Bundle Product Samples Section -->
    <div class="bundle-section-wrap">
      {% section 'bundle-product-samples-three' %}
    </div>

    {% render 'product-add-to-cart-samples3', product: product %}
    <span class="js-scroll visually-hidden" data-callback="addToCart"></span>
    <div class="product__links">
      <button class="js-toggleShipping">Shipping & Returns</button>
    </div>
  </div>
  {% section 'product-shipping' %}

</div>

{% render 'products-slider',
  list: product.metafields["global"]["related-products"],
  title: 'You might also like:'
%}

{% comment %} {% render 'product-add-to-cart-bar', product: product %} {% endcomment %}
{% render 'product-arrow' %}

<script>
document.addEventListener("DOMContentLoaded", function () {
  const addToCartButton = document.querySelector("#bundle-add-to-cart-button");
  const qtyInput = document.querySelector("#qtyInput");
  const qtyMinus = document.querySelector(".js-qtyMinus");
  const qtyPlus = document.querySelector(".js-qtyPlus");
  let quantity = 1; // Default quantity

  // Ensure elements exist before proceeding
  if (!addToCartButton) {
    console.error("Add to Cart button not found.");
    return;
  }

  // Dropdowns and hidden inputs for syncing values
  const dropdowns = {
    sample1: document.getElementById("sample1"),
    sample2: document.getElementById("sample2"),
    sample3: document.getElementById("sample3"),
  };

  const hiddenInputs = {
    sample1: document.getElementById("hidden-sample1"),
    sample2: document.getElementById("hidden-sample2"),
    sample3: document.getElementById("hidden-sample3"),
  };

  // Ensure all dropdowns exist
  if (!dropdowns.sample1 || !dropdowns.sample2 || !dropdowns.sample3) {
    console.error("One or more sample dropdowns are missing.");
    return;
  }

  // Function to check if all dropdowns have valid selections
  const areAllSelectionsMade = () => {
    return Object.values(dropdowns).every(
      (dropdown) => dropdown && dropdown.value !== ""
    );
  };

  // Function to toggle the Add to Cart button state
  const toggleAddToCartButton = () => {
    const allSelectionsMade = areAllSelectionsMade();
    addToCartButton.disabled = !allSelectionsMade;
    addToCartButton.textContent = allSelectionsMade
      ? "Add Bundle to Cart"
      : "Select All Items to Add";

    console.log("Button state updated:", allSelectionsMade);
  };

  // Reset bundle inputs after adding to cart
  const resetBundleInputs = () => {
    console.log("Resetting bundle inputs...");

    quantity = 1; // Reset quantity
    qtyInput.value = quantity;
    qtyMinus.disabled = true; // Disable minus button on reset

    // Reset dropdowns to default state
    Object.values(dropdowns).forEach((dropdown) => {
      if (dropdown) dropdown.value = "";
    });

    // Update hidden inputs
    Object.values(hiddenInputs).forEach((input) => {
      if (input) input.value = "";
    });

    // Ensure Add to Cart button is disabled after reset
    addToCartButton.disabled = true;
    addToCartButton.textContent = "Select All Items to Add";
  };

  // Sync dropdown values with hidden inputs and toggle button state
  Object.keys(dropdowns).forEach((key) => {
    if (dropdowns[key]) {
      dropdowns[key].addEventListener("change", () => {
        setTimeout(() => {
          hiddenInputs[key].value = dropdowns[key].value;
          toggleAddToCartButton();
        }, 10); // Small delay ensures values are updated before checking state
      });
    }
  });

  // Initialize button state
  addToCartButton.disabled = true;
  toggleAddToCartButton();

  // Handle quantity adjustments for the bundle area only
  if (qtyMinus && qtyPlus && qtyInput) {
    const updateQuantityDisplay = () => {
      qtyInput.value = quantity;
      qtyMinus.disabled = quantity <= 1;
    };

    qtyPlus.addEventListener("click", (e) => {
      e.preventDefault();
      quantity++;
      updateQuantityDisplay();
    });

    qtyMinus.addEventListener("click", (e) => {
      e.preventDefault();
      if (quantity > 1) {
        quantity--;
        updateQuantityDisplay();
      }
    });

    // Ensure correct quantity state on page load
    updateQuantityDisplay();
  }

  // Add event listener for "Add to Cart" button
  addToCartButton.addEventListener("click", async (event) => {
    event.preventDefault();

    // Main product and bundle items
    const mainProductId = document.getElementById("main-product-id")?.value;

    if (!mainProductId) {
      console.error("Main product ID is missing.");
      alert("An error occurred. Please refresh the page and try again.");
      return;
    }

    const sample1 = hiddenInputs.sample1.value;
    const sample2 = hiddenInputs.sample2.value;
    const sample3 = hiddenInputs.sample3.value;

    // Ensure all selected samples exist
    if (!sample1 || !sample2 || !sample3) {
      console.warn("One or more samples are missing when adding to cart.");
      alert("Please select all 3 samples before adding to cart.");
      return;
    }

    // Generate a unique bundle ID
    const bundleId = `bundle-${Date.now()}`;

    // Create an array of items to add to the cart
    const items = [
      {
        id: mainProductId,
        quantity: quantity,
        properties: {
          bundle_id: bundleId,
          bundle_label: "Samples 3 Pack",
        },
      },
      {
        id: sample1,
        quantity: quantity,
        properties: {
          bundle_id: bundleId,
          bundle_label: "Samples 3 Pack",
          template_suffix: "catalog-product",
        },
      },
      {
        id: sample2,
        quantity: quantity,
        properties: {
          bundle_id: bundleId,
          bundle_label: "Samples 3 Pack",
          template_suffix: "catalog-product",
        },
      },
      {
        id: sample3,
        quantity: quantity,
        properties: {
          bundle_id: bundleId,
          bundle_label: "Samples 3 Pack",
          template_suffix: "catalog-product",
        },
      },
    ];

    console.log("Submitting items:", items);

    try {
      addToCartButton.disabled = true;
      addToCartButton.textContent = "Adding...";

      const response = await fetch("/cart/add.js", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify({ items }),
      });

      if (!response.ok) {
        const errorDetails = await response.json();
        console.error("Shopify Error Response:", errorDetails);
        throw new Error("Failed to add items to the cart");
      }

      console.log("Items successfully added to cart.");

      // Reset bundle inputs
      resetBundleInputs();

      addToCartButton.disabled = true;
    } catch (error) {
      console.error("Error adding items to the cart:", error);
      alert("Sorry, something went wrong while adding items to the cart.");
      addToCartButton.disabled = false;
      addToCartButton.textContent = "Add Bundle to Cart";
    }
  });
});
</script>